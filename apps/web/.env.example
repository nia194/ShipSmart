# ─────────────────────────────────────────────────────────────
# ShipSmart Web — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# See also: docs/frontend-runtime-checklist.md
# ─────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED) ──────────────────────────────────────
# Source: Supabase dashboard > Settings > API
# Note: Lovable used VITE_SUPABASE_PUBLISHABLE_KEY — same value, different name.
VITE_SUPABASE_URL=https://fihrsfvohaxhmqrcisyl.supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]

# ── Backend API Base URLs (optional — not yet implemented) ───
# Spring Boot Java backend — core transactional logic (quotes, shipments)
VITE_JAVA_API_BASE_URL=http://localhost:8080
# FastAPI Python backend — AI/orchestration workflows
VITE_PYTHON_API_BASE_URL=http://localhost:8000

# ── App Config (optional) ────────────────────────────────────
# Values: development | staging | production
VITE_APP_ENV=development
