# ─────────────────────────────────────────────────────────────
# ShipSmart Web — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Your Supabase project URL (from Supabase dashboard > Settings > API)
VITE_SUPABASE_URL=https://[SUPABASE_PROJECT_REF].supabase.co

# Supabase anon/public key (safe to expose in browser)
# NOTE: In the Lovable project this was named VITE_SUPABASE_PUBLISHABLE_KEY.
# We rename it here for clarity. Update your Supabase client import accordingly.
VITE_SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]

# ── Backend API Base URLs ──────────────────────────────────────
# Spring Boot Java API
VITE_JAVA_API_BASE_URL=http://localhost:8080

# FastAPI Python API
VITE_PYTHON_API_BASE_URL=http://localhost:8000

# ── App Config ────────────────────────────────────────────────
VITE_APP_ENV=development
