# ─────────────────────────────────────────────────────────────
# ShipSmart Web — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED) ──────────────────────────────────────
VITE_SUPABASE_URL=https://fihrsfvohaxhmqrcisyl.supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]

# ── Backend API Base URLs ────────────────────────────────────
# Spring Boot Java backend — core transactional logic
VITE_JAVA_API_BASE_URL=http://localhost:8080
# FastAPI Python backend — AI/orchestration (skeleton, not active yet)
VITE_PYTHON_API_BASE_URL=http://localhost:8000

# ── Feature Flags ────────────────────────────────────────────
# Route traffic to Java API instead of legacy Supabase edge functions.
# Local dev: set to "true" when running Java backend locally.
# Production (Render): all set to "true" via render.yaml.
VITE_USE_JAVA_QUOTES=false
VITE_USE_JAVA_SAVED_OPTIONS=false
VITE_USE_JAVA_BOOKING_REDIRECT=false

# ── App Config ───────────────────────────────────────────────
# Values: development | staging | production
VITE_APP_ENV=development
