# ─────────────────────────────────────────────────────────────
# ShipSmart Java API — Environment Variables
# Copy to .env for local development. Never commit .env.
# In production: set these directly in Render service settings.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# ── Database (Supabase Postgres) ──────────────────────────────
# Connection pooler URL from Supabase dashboard > Settings > Database
DATABASE_URL=jdbc:postgresql://[SUPABASE_DB_HOST]:5432/postgres?sslmode=require
DATABASE_USERNAME=[SUPABASE_DB_USER]
DATABASE_PASSWORD=[SUPABASE_DB_PASSWORD]

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://[SUPABASE_PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SUPABASE_SERVICE_ROLE_KEY]
SUPABASE_JWT_SECRET=[YOUR_SUPABASE_JWT_SECRET]

# ── Security ──────────────────────────────────────────────────
# Set to true in production to enforce JWT secret is present.
REQUIRE_JWT_SECRET=false

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Internal Service-to-Service URLs ─────────────────────────
INTERNAL_PYTHON_API_URL=http://localhost:8000
