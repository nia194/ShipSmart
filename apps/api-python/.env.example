# ─────────────────────────────────────────────────────────────
# ShipSmart Python API — Environment Variables
# Copy to .env for local development. Never commit .env.
# In production: set these in Render service environment settings.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Internal Service-to-Service URLs ─────────────────────────
INTERNAL_JAVA_API_URL=http://localhost:8080

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── LLM ──────────────────────────────────────────────────────
# Set LLM_PROVIDER=openai to enable real completions (requires OPENAI_API_KEY)
# Leave empty to use EchoClient placeholder (no external AI calls)
LLM_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# ── Embeddings ───────────────────────────────────────────────
# Set EMBEDDING_PROVIDER=openai for real embeddings (requires OPENAI_API_KEY)
# Leave empty to use LocalHashEmbedding placeholder
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=256

# ── Vector Store ─────────────────────────────────────────────
VECTOR_STORE_TYPE=memory

# ── RAG ──────────────────────────────────────────────────────
RAG_TOP_K=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_DOCUMENTS_PATH=data/documents

# ── Providers ────────────────────────────────────────────────
SHIPPING_PROVIDER=mock

# ── Tools ────────────────────────────────────────────────────
ENABLE_TOOLS=true
