# ─────────────────────────────────────────────────────────────
# ShipSmart Python API — Environment Variables
# Copy to .env for local development. Never commit .env.
# In production: set these in Render service environment settings.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://[SUPABASE_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SUPABASE_SERVICE_ROLE_KEY]

# ── Internal Service-to-Service URLs ─────────────────────────
# Used for Python → Java calls. On Render, use internal network URL.
INTERNAL_JAVA_API_URL=http://localhost:8080

# ── AI / LLM (placeholder) ────────────────────────────────────
# TODO: Add LLM provider API key when AI features are implemented
# OPENAI_API_KEY=[YOUR_OPENAI_API_KEY]
# ANTHROPIC_API_KEY=[YOUR_ANTHROPIC_API_KEY]

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://[RENDER_SERVICE_NAME_WEB].onrender.com
