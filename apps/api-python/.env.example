# ─────────────────────────────────────────────────────────────
# ShipSmart Python API — Environment Variables
# Copy to .env for local development. Never commit .env.
# In production: set these in Render service environment settings.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Internal Service-to-Service URLs ─────────────────────────
INTERNAL_JAVA_API_URL=http://localhost:8080

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── LLM ──────────────────────────────────────────────────────
# Options: openai, gemini, llama, "" (empty = EchoClient placeholder)
# Falls back to EchoClient if credentials are missing
LLM_PROVIDER=
LLM_TIMEOUT=30
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# ── Task-based LLM routing ───────────────────────────────────
# Optional: route different tasks to different providers.
# Empty string = inherit LLM_PROVIDER above. Unknown / missing-key
# providers fall through to LLM_PROVIDER_FALLBACK, then EchoClient.
#   reasoning  → shipping advisor, tracking advisor
#   synthesis  → /api/v1/rag/query, recommendation summary
#   fallback   → safety net used when a task provider is unavailable
LLM_PROVIDER_REASONING=
LLM_PROVIDER_SYNTHESIS=
LLM_PROVIDER_FALLBACK=echo

# ── OpenAI (https://platform.openai.com/) ───────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini (https://ai.google.dev/) ──────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic / Claude (https://console.anthropic.com/) ─────
# Set ANTHROPIC_API_KEY and pick a model. Enable for reasoning by also
# setting LLM_PROVIDER_REASONING=anthropic above.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Llama / Ollama (https://ollama.com/) ────────────────────
# Local model via Ollama — no API key needed, just Ollama running
LLAMA_BASE_URL=http://localhost:11434
LLAMA_MODEL=llama3.2

# ── Embeddings ───────────────────────────────────────────────
# Set EMBEDDING_PROVIDER=openai for real embeddings (requires OPENAI_API_KEY)
# Leave empty to use LocalHashEmbedding placeholder
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=256

# ── Vector Store ─────────────────────────────────────────────
# Options: memory (in-process, lost on restart), pgvector (Postgres-backed)
VECTOR_STORE_TYPE=memory
# Required when VECTOR_STORE_TYPE=pgvector. Postgres connection string.
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=
PGVECTOR_TABLE=rag_chunks
# Auto-ingest documents on startup if the pgvector table is empty.
RAG_AUTO_INGEST=true

# ── RAG ──────────────────────────────────────────────────────
RAG_TOP_K=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_DOCUMENTS_PATH=data/documents

# ── Providers ────────────────────────────────────────────────
# Options: mock, ups, fedex, dhl, usps
# Falls back to mock if credentials are missing or invalid
SHIPPING_PROVIDER=mock

# ── UPS (https://developer.ups.com/) ────────────────────────
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_BASE_URL=https://onlinetools.ups.com

# ── FedEx (https://developer.fedex.com/) ────────────────────
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_BASE_URL=https://apis.fedex.com

# ── DHL Express (https://developer.dhl.com/) ────────────────
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_BASE_URL=https://express.api.dhl.com

# ── USPS (https://developer.usps.com/) ──────────────────────
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
USPS_BASE_URL=https://api.usps.com

# ── Tools ────────────────────────────────────────────────────
ENABLE_TOOLS=true

# ── Rate limiting (per IP, slowapi syntax) ──────────────────
RATE_LIMIT_ADVISOR=10/minute
RATE_LIMIT_ORCHESTRATION=20/minute
