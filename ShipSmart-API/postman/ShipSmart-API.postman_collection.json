    },
    {
      "name": "Workflow (UC3/UC4) chain",
      "item": [
        {
          "name": "process",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('terminal or suspended state', () => pm.expect(['completed','awaiting_review','blocked']).to.include(b.status));",
                  "pm.collectionVariables.set('workflow_id', b.workflow_id);",
                  "pm.test('has hs_code + decisions', () => { pm.expect(b.hs_code).to.be.a('string'); pm.expect(b.decisions).to.be.an('array'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/workflow/process",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "workflow",
                "process"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin_country\": \"US\",\n  \"destination_country\": \"BR\",\n  \"declared_value_usd\": 600,\n  \"weight_lbs\": 3,\n  \"description\": \"camera drone with lithium battery\"\n}"
            }
          }
        },
        {
          "name": "GET {id}",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('same id', () => pm.expect(pm.response.json().workflow_id).to.eql(pm.collectionVariables.get('workflow_id')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/workflow/{{workflow_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "workflow",
                "{{workflow_id}}"
              ]
            }
          }
        },
        {
          "name": "review cleared",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// 200 completed if it was awaiting review; 409 if already terminal (straight-through). Both valid.",
                  "pm.test('200 or 409', () => pm.expect([200,409]).to.include(pm.response.code));",
                  "if (pm.response.code === 200) pm.test('completed', () => pm.expect(['completed','blocked']).to.include(pm.response.json().status));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/workflow/{{workflow_id}}/review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "workflow",
                "{{workflow_id}}",
                "review"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"determination\": \"cleared\",\n  \"note\": \"checked import rules\"\n}"
            }
          }
        },
        {
          "name": "GET unknown id -> 404",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('404', () => pm.response.to.have.status(404));"
