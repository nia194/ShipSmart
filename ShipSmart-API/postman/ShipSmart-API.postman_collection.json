{
  "info": {
    "name": "ShipSmart-API",
    "description": "FastAPI AI service contract \u2014 health/ready/info, concierge, compliance (UC2), workflow (UC3/UC4) chain, compare, RAG, orchestration, recommendation. Structural assertions (keyless-safe).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('no server error', () => pm.expect(pm.response.code).to.be.below(500));",
          "pm.test('responds < 15s', () => pm.expect(pm.response.responseTime).to.be.below(15000));"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "workflow_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health & readiness",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "GET /ready",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('resolved flags + llm chains', () => { pm.expect(b).to.have.property('concierge_enabled'); pm.expect(b).to.have.property('workflow_enabled'); pm.expect(b.llm_chains).to.have.property('reasoning'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/ready",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "ready"
              ]
            }
          }
        },
        {
          "name": "GET /api/v1/info",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('publishes shipping_scope', () => pm.expect(pm.response.json()).to.have.property('shipping_scope'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/info",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "info"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Concierge",
      "item": [
        {
          "name": "chat \u2014 greeting",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('greeting handled (not RAG dump)', () => { pm.expect(b.decisions).to.include('concierge:greeting'); pm.expect(b.reply).to.match(/^Hi!/); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/concierge/chat",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "concierge",
                "chat"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"hi\",\n  \"state\": null\n}"
            }
          }
        },
        {
          "name": "chat \u2014 quote gathers/dispatches",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('quote intent, not an empty refusal', () => { pm.expect(b.state.intent).to.eql('quote'); pm.expect(b.reply).to.not.match(/don.t have enough/i); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/concierge/chat",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "concierge",
                "chat"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"get me a quote to ship from chicago to denver, 5 lb\",\n  \"state\": null\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Compliance (UC2)",
      "item": [
        {
          "name": "compliance/check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('advisory verdict + findings', () => { pm.expect(['action_required','review_recommended','advisory']).to.include(b.verdict); pm.expect(b.findings).to.be.an('array'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Request-Id",
                "value": "{{$guid}}"
