{
  "info": {
    "name": "ShipSmart-API",
    "description": "FastAPI AI service contract \u2014 health/ready/info, concierge (chat + recall), advisor (shipping/tracking), agent, SSE assistant stream, compliance (UC2), workflow (UC3/UC4) chain, compare, RAG (ingest + query), orchestration, recommendation, feedback, and the fail-closed admin AI-controls kill switches. Structural assertions (keyless-safe).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('no server error', () => pm.expect(pm.response.code).to.be.below(500));",
          "pm.test('responds < 15s', () => pm.expect(pm.response.responseTime).to.be.below(15000));"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "workflow_id",
      "value": ""
    },
    {
      "key": "session_id",
      "value": ""
    },
    {
      "key": "admin_token",
      "value": "e2e-admin-token-nonsecret"
    }
  ],
