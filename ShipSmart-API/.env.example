# ShipSmart API (Python / FastAPI + MCP tools) - environment variables
# Copy to .env and fill in real values for local development.
# Production values are set in the Render dashboard (never commit real secrets).

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
AUDIT_SINK=logging               # audit + tracing sink: logging (default) | memory
AI_EVENT_SINK=logging            # AI-event observability sink: logging (default) | memory
PSEUDONYM_SECRET=dev-pseudonym-secret-change-me   # pseudonymize identity at write time — OVERRIDE in prod
STATE_SECRET=dev-state-secret-change-me            # HMAC-sign client-echoed conversation state — OVERRIDE in prod
ADMIN_API_TOKEN=                 # runtime AI-controls admin token; EMPTY = /admin/ai-controls does not exist (fail-closed)
FEEDBACK_ENABLED=true            # explicit user feedback endpoint (POST /api/v1/feedback; 404 when false)
RATE_LIMIT_FEEDBACK=30/minute    # per-user feedback cap (§6.6 anti-gaming)

# Shipping scope (platform policy) — worldwide (default, cross-border allowed) |
# domestic (only deliveries within DOMESTIC_COUNTRY; cross-border requests get 422).
# Published on GET /api/v1/info; Web/Orchestrator/MCP read + enforce the same value.
SHIPPING_SCOPE=worldwide
DOMESTIC_COUNTRY=US              # ISO-3166 alpha-2 home country when SHIPPING_SCOPE=domestic

# Inter-service / CORS
INTERNAL_JAVA_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# LLM Provider
# Set to one of: openai, gemini, anthropic, llama, "" (empty = EchoClient mock)
LLM_PROVIDER=openai
LLM_TIMEOUT=30
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# Task-based LLM Routing
# Per-task provider selection. Empty = inherit LLM_PROVIDER.
# Set LLM_PROVIDER_REASONING=scripted (non-production only) for a deterministic,
# keyless tool-calling stub that drives the agent loop without API keys.
LLM_PROVIDER_REASONING=openai
LLM_PROVIDER_SYNTHESIS=openai
LLM_PROVIDER_FALLBACK=echo

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Gemini (optional)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5

# Llama / Ollama (optional)
LLAMA_BASE_URL=http://localhost:11434
LLAMA_MODEL=llama3.2

# Embeddings
# Set to "openai" for semantic search, leave empty for LocalHashEmbedding.
# Keep dimensions aligned with the pgvector migration when using pgvector.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Vector Store (RAG persistence)
# memory = in-process (lost on restart); pgvector = Supabase PostgreSQL; mcp = remote MCP vector backend
VECTOR_STORE_TYPE=pgvector
DATABASE_URL=postgresql://user:pass@project-ref.pooler.supabase.com:6543/postgres?sslmode=require
PGVECTOR_TABLE=rag_chunks
MCP_SERVER_URL=
MCP_API_KEY=

# RAG / Knowledge Base
RAG_AUTO_INGEST=true
RAG_DOCUMENTS_PATH=data/documents
RAG_TOP_K=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# Retrieval (hybrid + iterative) — defaults reproduce today's dense-only, normal mode
RAG_MODE=normal                  # normal | iterative  ("agentic" accepted as a deprecated alias)
RAG_HYBRID=false                 # false = dense-only (today), true = dense + sparse
RAG_HYBRID_ALPHA=0.5             # dense vs sparse fusion weight (0..1; 1.0 = all dense)
RAG_ITERATIVE_MAX_STEPS=3        # max plan/retrieve steps when RAG_MODE=iterative (legacy: RAG_AGENTIC_MAX_STEPS)
RAG_QUERY_LOG=false             # true = best-effort iterative-RAG traces to rag_query_log (Infra table)

# LLM request-time fallback chain + context budget
LLM_FALLBACK_CHAIN=              # csv, e.g. openai,gemini,echo (empty = single client, today)
LLM_RETRY_MAX_ATTEMPTS=2         # retries per provider before the next in the chain
LLM_MAX_CONTEXT_TOKENS=8000      # token budget for retrieved context fed to the LLM

# Per-task overrides (optional; empty = inherit the global LLM_* value)
LLM_MODEL_REASONING=             # model override for the reasoning task
LLM_MODEL_SYNTHESIS=             # model override for the synthesis task
LLM_TEMPERATURE_REASONING=       # temperature override for reasoning (clamped <= 0.3)
LLM_TEMPERATURE_SYNTHESIS=       # temperature override for synthesis (clamped <= 0.3)
LLM_MAX_TOKENS_REASONING=        # max output tokens for reasoning
LLM_MAX_TOKENS_SYNTHESIS=        # max output tokens for synthesis

# Guardrails (recommended on; set false for the legacy passthrough)
GUARDRAILS_ENABLED=true          # fence/sanitize + detect prompt injection on advisor/RAG calls
GUARDRAILS_BLOCK_ON_INJECTION=true  # block on detected injection (else neutralize and continue)

# ShipSmart MCP (tool server)
# HTTP endpoint of the ShipSmart-MCP service that owns the shipping tools.
# Leave empty for local dev without MCP — advisor/orchestration routes will 503.
SHIPSMART_MCP_URL=http://localhost:8001
SHIPSMART_MCP_API_KEY=

# Rate Limiting
RATE_LIMIT_ADVISOR=10/minute
RATE_LIMIT_ORCHESTRATION=20/minute
RATE_LIMIT_COMPARE=10/minute
RATE_LIMIT_AGENT=10/minute
RATE_LIMIT_COMPLIANCE=10/minute
RATE_LIMIT_WORKFLOW=10/minute
RATE_LIMIT_CONCIERGE=60/minute   # interactive chat: a single user easily exceeds 10/min

# Agent — model-driven, read-only tool-calling loop (POST /api/v1/agent/run)
AGENT_ENABLED=true               # gate the agent endpoint (404 when false)
AGENT_MAX_STEPS=5                # hard cost bound on the agent loop

# Conversational Concierge — multi-turn, slot-filling shipment-setup assistant
# (POST /api/v1/concierge/chat). Deterministic-first; an optional reasoning model
# enriches NLU (compound intent, corrections, disambiguation) + phrasing. Drives the
# full multi-agent workflow for international shipments when COMPLIANCE_EXPLICIT_ENABLED
# + WORKFLOW_ENABLED are on (and SHIPPING_SCOPE=worldwide).
CONCIERGE_ENABLED=false              # gate the concierge endpoint (404 when false)
CONCIERGE_MAX_TURNS=12              # soft bound on a single conversation
# Server-side recall: persist the transcript + merged state by anonymous session id so a
# chat survives a page reload. "memory" (default, keyless) = process-lifetime store;
# "postgres" = durable backend via asyncpg + DATABASE_URL (conversations migration).
CONVERSATION_STORE=memory          # "memory" | "postgres"
CONVERSATION_MAX_MESSAGES=50       # recall window: max transcript turns loaded

# Compliance (UC2) — deterministic structural + grounded-area analysis with an
# optional model-driven critic (POST /api/v1/compliance/check). Advisory only.
COMPLIANCE_ENABLED=true              # gate the compliance endpoint (404 when false)
COMPLIANCE_EXPLICIT_ENABLED=true     # additive: run the hard compliance pass on the chat/workflow paths; false = normal flow only (skips the workflow HITL interrupt)
COMPLIANCE_CRITIQUE_MAX_ROUNDS=0     # 0 = critic off (deterministic only); >0 enables the UC2 critic
COMPLIANCE_MAX_GAP_AREAS=3           # max gap areas accepted from the critic per round
COMPLIANCE_VALUE_THRESHOLD_USD=2500  # declared value (USD) that flags a commercial invoice (international)

# Workflow (UC3/UC4) — multi-agent durable workflow: classify -> (landed-cost || routing)
# -> compliance(+UC2) -> documentation, with a human-in-the-loop interrupt on unverified
# high-risk shipments (POST/GET /api/v1/workflow/...). OFF by default.
WORKFLOW_ENABLED=false               # gate the workflow endpoints (404 when false)
WORKFLOW_DURABLE=false               # false = in-memory checkpointer; true = SQLite (survives restarts)
WORKFLOW_CHECKPOINT_PATH=workflow_checkpoints.db   # SQLite file when WORKFLOW_DURABLE=true
WORKFLOW_HIGH_RISK_AREAS=lithium_battery,import_restriction  # unverified area here -> human review
