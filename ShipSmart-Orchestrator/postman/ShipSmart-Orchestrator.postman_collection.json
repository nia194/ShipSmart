{
  "info": {
    "name": "ShipSmart-Orchestrator",
    "description": "Java transactional API \u2014 health + the shipments chain (JWT auth, idempotency, ownership scoping), quotes fan-out with trust metadata, saved options + analytics, booking redirect audit, and provider metrics. A collection pre-request mints an HS256 JWT with the shared e2e test secret (NOT production).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function b64url(wa){ return CryptoJS.enc.Base64.stringify(wa).replace(/=+$/,'').replace(/\\+/g,'-').replace(/\\//g,'_'); }",
          "function mint(sub){",
          "  var now = Math.floor(Date.now()/1000);",
          "  var h = b64url(CryptoJS.enc.Utf8.parse(JSON.stringify({alg:'HS256',typ:'JWT'})));",
          "  var p = b64url(CryptoJS.enc.Utf8.parse(JSON.stringify({sub:sub, role:'authenticated', iat:now, exp:now+900})));",
          "  var s = b64url(CryptoJS.HmacSHA256(h+'.'+p, pm.environment.get('SUPABASE_JWT_SECRET')));",
          "  return h+'.'+p+'.'+s;",
          "}",
          "pm.collectionVariables.set('jwt', mint(pm.environment.get('USER_A')));",
          "pm.collectionVariables.set('jwt_userB', mint(pm.environment.get('USER_B')));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('no server error', () => pm.expect(pm.response.code).to.be.below(500));",
          "pm.test('responds < 5s', () => pm.expect(pm.response.responseTime).to.be.below(5000));"
        ]
      }
    }
  ],
