# EditorConfig — consistent whitespace across editors. https://editorconfig.org
# Indentation mirrors google-java-format (AOSP variant): 4 spaces, 100 cols.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.java]
indent_size = 4
max_line_length = 100

[*.gradle]
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
